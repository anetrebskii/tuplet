# LLM Provider — pick one:

# Option A: OpenRouter (recommended)
OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_MODEL=anthropic/claude-sonnet-4   # optional, defaults to anthropic/claude-sonnet-4

# Option B: Anthropic direct
# ANTHROPIC_API_KEY=your-anthropic-key

# Server
PORT=3000

# Workspace storage — set GCS_BUCKET to use Google Cloud Storage instead of local filesystem
# GCS_BUCKET=your-gcs-bucket-name
